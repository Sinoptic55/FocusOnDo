[Unit]
Description=Pomodoro TMS Backend (FastAPI)
After=network.target postgresql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/pomodoro-tms/src/backend
Environment="PATH=/var/www/pomodoro-tms/src/backend/venv/bin"
EnvironmentFile=/var/www/pomodoro-tms/.env
ExecStart=/var/www/pomodoro-tms/src/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
